{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Danmaku-Overlay",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420/",
    "beforeDevCommand": "pnpm --prefix frontend dev",
    "beforeBuildCommand": "pnpm --prefix frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "Danmaku-Overlay",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/go-backend"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
